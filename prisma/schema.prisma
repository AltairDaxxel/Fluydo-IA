// Fluydo.IA - Schema Prisma (SQL Server) - Multi-emitente
// Regra de isolamento: todas as consultas devem incluir id_emitente no WHERE.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Emitente {
  id           String    @id @db.VarChar(50)
  cnpjEmitente String?   @map("cnpj_emitente") @db.VarChar(20)
  telefone     String?   @map("Telefone") @db.VarChar(15)
  nome         String?   @map("Nome") @db.VarChar(200)

  produtos   Produto[]
  clientes   Cliente[]
  pedidos    Pedido[]
  pagamentos Pagamento[]

  @@map("Emitentes")
}

model Produto {
  id         String   @id @db.VarChar(50)
  idEmitente String   @map("id_emitente") @db.VarChar(50)
  codigo        String   @map("Codigo") @db.VarChar(30)
  descricao     String   @db.VarChar(100)
  dim1          Decimal? @db.Decimal(7, 3)
  dim2          Decimal? @db.Decimal(7, 3)
  dim3          Decimal? @db.Decimal(7, 3)
  dim4          Decimal? @db.Decimal(7, 3)
  material      String?  @map("Material") @db.VarChar(20)
  unidade       String?  @map("Unidade") @db.VarChar(6)
  aplicacao     String?  @map("Aplicacao") @db.VarChar(100)
  estoque       Decimal  @map("Estoque") @db.Decimal(18, 3)
  precoUnitario Decimal? @map("PrecoUnitario") @db.Decimal(18, 3)
  ipi           Decimal? @map("IPI") @db.Decimal(6, 2)
  ativo         Int      @map("Ativo")

  emitente    Emitente     @relation(fields: [idEmitente], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pedidoItens PedidoItem[]

  @@map("Produtos")
}

model Cliente {
  id         String  @id @db.VarChar(50)
  idEmitente String  @map("id_emitente") @db.VarChar(50)
  cnpj        String? @map("CNPJ") @db.VarChar(20)
  cpf         String? @map("CPF") @db.VarChar(14)
  telefone    String? @map("Telefone") @db.VarChar(30)
  email       String? @map("e-mail") @db.VarChar(100)
  senha       String? @map("Senha") @db.VarChar(255)
  ativo       Int     @map("Ativo")

  emitente Emitente @relation(fields: [idEmitente], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pedidos  Pedido[]

  @@map("Cliente")
}

model Pedido {
  id         String   @id @db.VarChar(50)
  idEmitente String   @map("id_emitente") @db.VarChar(50)
  clienteId  String   @map("ClienteId") @db.VarChar(50)
  createdAt  DateTime @map("createdAt")
  updatedAt  DateTime @map("updatedAt")

  emitente Emitente     @relation(fields: [idEmitente], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cliente  Cliente      @relation(fields: [clienteId], references: [id])
  itens    PedidoItem[]

  @@map("Pedido")
}

model PedidoItem {
  id         String  @id @db.VarChar(50)
  pedidoId   String  @map("PedidoId") @db.VarChar(50)
  produtoId  String  @map("ProdutoId") @db.VarChar(50)
  quantidade Decimal @db.Decimal(18, 3)
  precoUnit  Decimal @map("precoUnit") @db.Decimal(18, 3)

  pedido  Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("PedidoItens")
}

model Pagamento {
  id         String  @id @db.VarChar(50)
  idEmitente String  @map("id_emitente") @db.VarChar(50)
  codigo     String  @map("Codigo") @db.VarChar(20)
  descricao  String  @map("Descricao") @db.VarChar(100)

  emitente Emitente @relation(fields: [idEmitente], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("Pagamentos")
}

// Tabela de linhas de produto: regra pré-busca (exclusiva/bloqueada).
// Bloqueada = 'S' ou Aplicacao = 'Exclusiva' => não listar produtos, retornar mensagem fixa.
// ID no banco é GUID (string); use @db.UniqueIdentifier() se a coluna for uniqueidentifier.
model Linha {
  id        String  @id @map("ID") @db.VarChar(36)
  linha     String  @map("Linha") @db.VarChar(30)
  descricao String  @map("Descricao") @db.VarChar(200)
  bloqueada String? @map("Bloqueada") @db.VarChar(1)
  aplicacao String? @map("Aplicacao") @db.VarChar(50)

  @@map("Linhas")
}

// Termos de produto oficiais: busca usa só palavras que estão aqui (ex.: "preciso de guia de nylon com 62" → busca "guia nylon 62").
model Vocabulario {
  id        String @id @db.VarChar(50)
  descricao String @map("Descricao") @db.VarChar(100)

  @@map("Vocabulario")
}

// Mensagens e textos do sistema (zero hardcoding no código)
model Configuracao {
  id    String @id @map("Chave") @db.VarChar(80)
  valor String @map("Valor") @db.NVarChar(Max)

  @@map("Configuracoes")
}

// Sistema de ajuda — conteúdo carregado apenas do SQL Server
model FluydoAjuda {
  id         Int      @id @default(autoincrement())
  slug       String   @db.VarChar(100)
  titulo     String   @db.VarChar(200)
  resumo     String?  @db.VarChar(500)
  conteudoMd String   @map("ConteudoMd") @db.NVarChar(Max)
  tags       String?  @db.VarChar(200)
  ordem      Int      @default(0)
  ativo      Int      @default(1)
  visibilidade String @db.VarChar(20)

  gatilhos FluydoAjudaGatilho[]
  exemplos FluydoAjudaExemplo[]

  @@unique([slug])
  @@map("FluydoAjuda")
}

model FluydoAjudaGatilho {
  id         Int    @id @default(autoincrement())
  ajudaId    Int    @map("AjudaId")
  padrao     String @map("Padrao") @db.VarChar(100)
  tipoPadrao String @map("TipoPadrao") @db.VarChar(20)
  peso       Int    @default(1)
  ativo      Int    @default(1)

  ajuda FluydoAjuda @relation(fields: [ajudaId], references: [id], onDelete: Cascade)
  @@map("FluydoAjudaGatilhos")
}

model FluydoAjudaExemplo {
  id        Int     @id @default(autoincrement())
  ajudaId   Int     @map("AjudaId")
  exemplo   String  @db.VarChar(500)
  observacao String? @map("Observacao") @db.VarChar(300)
  ordem     Int     @default(0)
  ativo     Int     @default(1)

  ajuda FluydoAjuda @relation(fields: [ajudaId], references: [id], onDelete: Cascade)
  @@map("FluydoAjudaExemplos")
}
